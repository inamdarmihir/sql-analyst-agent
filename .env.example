# ─── LLM Provider ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# Optional: swap to a different model string understood by LangChain
# MODEL=anthropic:claude-sonnet-4-6

# ─── Database Connection ───────────────────────────────────────────────────────
# Leave blank to use the bundled SQLite demo database (data/ecommerce.db).
# Replace with any SQLAlchemy-compatible URL to target a different database.

# SQLite (default – no extra driver needed)
DATABASE_URL=sqlite:///data/ecommerce.db

# PostgreSQL  →  pip install "sql-analyst-agent[postgres]"
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/mydb

# MySQL / MariaDB  →  pip install "sql-analyst-agent[mysql]"
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/mydb

# SQL Server  →  pip install "sql-analyst-agent[mssql]"
# DATABASE_URL=mssql+pyodbc://user:password@localhost:1433/mydb?driver=ODBC+Driver+18+for+SQL+Server

# CockroachDB (PostgreSQL-compatible)
# DATABASE_URL=cockroachdb+psycopg2://user:password@localhost:26257/mydb

# DuckDB (in-process analytics)  →  pip install duckdb-engine
# DATABASE_URL=duckdb:///data/analytics.duckdb
